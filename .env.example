# ── Server ────────────────────────────────────────────────────────────────────
PORT=3005

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/verbalise?schema=public"

# ── Authentication ────────────────────────────────────────────────────────────
# Strong random secret used to sign JWTs — generate with: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-here

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM=no-reply@verbalise.ai
